<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             Scheduled Action: Daily License Expiry Check
        ============================================================ -->
        <record id="action_license_expiry_check" model="ir.cron">
            <field name="name">TransitOps: Daily License Expiry Alert</field>
            <field name="model_id" ref="model_transit_dashboard"/>
            <field name="state">code</field>
            <field name="code">model.action_check_license_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
