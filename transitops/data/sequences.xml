<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Trip Number Sequence -->
        <record id="seq_transit_trip" model="ir.sequence">
            <field name="name">Transit Trip Sequence</field>
            <field name="code">transit.trip.sequence</field>
            <field name="prefix">TRP/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Maintenance Reference Sequence -->
        <record id="seq_transit_maintenance" model="ir.sequence">
            <field name="name">Transit Maintenance Sequence</field>
            <field name="code">transit.maintenance.sequence</field>
            <field name="prefix">MNT/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Fuel Log Reference Sequence -->
        <record id="seq_transit_fuel_log" model="ir.sequence">
            <field name="name">Transit Fuel Log Sequence</field>
            <field name="code">transit.fuel.log.sequence</field>
            <field name="prefix">FUEL/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Expense Reference Sequence -->
        <record id="seq_transit_expense" model="ir.sequence">
            <field name="name">Transit Expense Sequence</field>
            <field name="code">transit.expense.sequence</field>
            <field name="prefix">EXP/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
