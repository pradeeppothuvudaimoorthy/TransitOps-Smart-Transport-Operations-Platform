<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             VEHICLE ANALYTICS REPORT: QWEB TEMPLATE
        ============================================================ -->
        <template id="report_transitops_vehicle_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">

                            <div class="row mb-4">
                                <div class="col-8">
                                    <h2>🚛 Vehicle Analytics Report</h2>
                                    <h3 class="text-primary">
                                        <t t-esc="doc.name"/> —
                                        <t t-esc="doc.registration_number"/>
                                    </h3>
                                </div>
                                <div class="col-4 text-end">
                                    <span t-attf-class="badge bg-#{doc.status == 'available' and 'success' or doc.status == 'on_trip' and 'primary' or doc.status == 'in_shop' and 'warning' or 'danger'}">
                                        <t t-esc="doc.status"/>
                                    </span>
                                </div>
                            </div>

                            <hr/>

                            <!-- Vehicle Info -->
                            <div class="row">
                                <div class="col-6">
                                    <h5>Vehicle Details</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr>
                                            <td><strong>Type</strong></td>
                                            <td><t t-esc="doc.vehicle_type"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Fuel Type</strong></td>
                                            <td><t t-esc="doc.fuel_type"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Region</strong></td>
                                            <td><t t-esc="doc.region or 'N/A'"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Max Load Capacity</strong></td>
                                            <td><t t-esc="doc.max_load_capacity"/> kg</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Current Odometer</strong></td>
                                            <td><t t-esc="doc.current_odometer"/> km</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Acquisition Cost</strong></td>
                                            <td><t t-esc="doc.acquisition_cost"/></td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <h5>Financial Analytics</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr>
                                            <td><strong>Total Fuel Cost</strong></td>
                                            <td><t t-esc="doc.total_fuel_cost"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Total Maintenance Cost</strong></td>
                                            <td><t t-esc="doc.total_maintenance_cost"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Total Operational Cost</strong></td>
                                            <td><t t-esc="doc.total_operational_cost"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Total Revenue</strong></td>
                                            <td><t t-esc="doc.total_revenue"/></td>
                                        </tr>
                                        <tr class="table-success">
                                            <td><strong>ROI</strong></td>
                                            <td>
                                                <t t-esc="round(doc.roi * 100, 2)"/>%
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Trip Summary -->
                            <div t-if="doc.trip_ids" class="mt-3">
                                <h5>Trip Summary (<t t-esc="len(doc.trip_ids)"/> trips)</h5>
                                <table class="table table-sm table-bordered table-striped">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Trip #</th>
                                            <th>Driver</th>
                                            <th>Route</th>
                                            <th>Distance (km)</th>
                                            <th>Revenue</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.trip_ids" t-as="trip">
                                            <tr>
                                                <td><t t-esc="trip.trip_number"/></td>
                                                <td><t t-esc="trip.driver_id.name"/></td>
                                                <td>
                                                    <t t-esc="trip.source"/> →
                                                    <t t-esc="trip.destination"/>
                                                </td>
                                                <td><t t-esc="trip.actual_distance"/></td>
                                                <td><t t-esc="trip.revenue"/></td>
                                                <td><t t-esc="trip.status"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>

                            <div class="mt-4 text-muted text-center">
                                <small>
                                    Generated by TransitOps Smart Transport Operations Platform
                                </small>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

        <!-- Report Action -->
        <record id="action_report_transit_vehicle" model="ir.actions.report">
            <field name="name">Vehicle Analytics Report</field>
            <field name="model">transit.vehicle</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">transitops.report_transitops_vehicle_document</field>
            <field name="report_file">transitops.report_transitops_vehicle_document</field>
            <field name="binding_model_id" ref="model_transit_vehicle"/>
            <field name="binding_type">report</field>
        </record>

    </data>
</odoo>
