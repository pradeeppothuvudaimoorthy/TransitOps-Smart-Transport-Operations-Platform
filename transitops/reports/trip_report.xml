<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             TRIP REPORT: QWEB TEMPLATE
        ============================================================ -->
        <template id="report_transitops_trip_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">

                            <!-- Report Header -->
                            <div class="row mb-4">
                                <div class="col-6">
                                    <h2>🚛 Trip Report</h2>
                                    <h3 class="text-primary">
                                        <t t-esc="doc.trip_number"/>
                                    </h3>
                                </div>
                                <div class="col-6 text-end">
                                    <div class="badge"
                                         t-attf-style="background-color: #6c757d; color: white; font-size: 14px;">
                                        Status: <t t-esc="doc.status"/>
                                    </div>
                                </div>
                            </div>

                            <hr/>

                            <!-- Trip Details -->
                            <div class="row">
                                <div class="col-6">
                                    <h5>Route Information</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr>
                                            <td><strong>Origin</strong></td>
                                            <td><t t-esc="doc.source"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Destination</strong></td>
                                            <td><t t-esc="doc.destination"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Planned Distance</strong></td>
                                            <td>
                                                <t t-esc="doc.planned_distance"/> km
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Actual Distance</strong></td>
                                            <td>
                                                <t t-esc="doc.actual_distance"/> km
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Cargo Weight</strong></td>
                                            <td>
                                                <t t-esc="doc.cargo_weight"/> kg
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <h5>Assignment</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr>
                                            <td><strong>Vehicle</strong></td>
                                            <td>
                                                <t t-esc="doc.vehicle_id.name"/>
                                                (<t t-esc="doc.vehicle_id.registration_number"/>)
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Driver</strong></td>
                                            <td><t t-esc="doc.driver_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Dispatch Date</strong></td>
                                            <td>
                                                <t t-esc="doc.dispatch_date"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Completion Date</strong></td>
                                            <td>
                                                <t t-esc="doc.completion_date or 'N/A'"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Odometer & Fuel -->
                            <div class="row mt-3">
                                <div class="col-6">
                                    <h5>Odometer Reading</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr>
                                            <td><strong>Start</strong></td>
                                            <td><t t-esc="doc.start_odometer"/> km</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Final</strong></td>
                                            <td><t t-esc="doc.final_odometer"/> km</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Distance Covered</strong></td>
                                            <td><t t-esc="doc.actual_distance"/> km</td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <h5>Financial Summary</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr>
                                            <td><strong>Fuel Used</strong></td>
                                            <td><t t-esc="doc.fuel_used"/> L</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Revenue</strong></td>
                                            <td>
                                                <t t-esc="doc.revenue"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Expenses -->
                            <div t-if="doc.expense_ids" class="mt-3">
                                <h5>Trip Expenses</h5>
                                <table class="table table-sm table-bordered table-striped">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Reference</th>
                                            <th>Type</th>
                                            <th>Amount</th>
                                            <th>Date</th>
                                            <th>Description</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.expense_ids" t-as="exp">
                                            <tr>
                                                <td><t t-esc="exp.reference"/></td>
                                                <td><t t-esc="exp.expense_type"/></td>
                                                <td><t t-esc="exp.amount"/></td>
                                                <td><t t-esc="exp.date"/></td>
                                                <td><t t-esc="exp.description or ''"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr class="table-warning">
                                            <td colspan="2"><strong>Total</strong></td>
                                            <td>
                                                <strong>
                                                    <t t-esc="sum(doc.expense_ids.mapped('amount'))"/>
                                                </strong>
                                            </td>
                                            <td colspan="2"/>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>

                            <!-- Footer -->
                            <div class="mt-4 text-muted text-center">
                                <small>
                                    Generated by TransitOps Smart Transport Operations Platform
                                </small>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

        <!-- Report Action -->
        <record id="action_report_transit_trip" model="ir.actions.report">
            <field name="name">Trip Report</field>
            <field name="model">transit.trip</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">transitops.report_transitops_trip_document</field>
            <field name="report_file">transitops.report_transitops_trip_document</field>
            <field name="binding_model_id" ref="model_transit_trip"/>
            <field name="binding_type">report</field>
        </record>

    </data>
</odoo>
