<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             ACTION WINDOW
        ============================================================ -->
        <record id="action_transit_driver" model="ir.actions.act_window">
            <field name="name">Drivers</field>
            <field name="res_model">transit.driver</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Register your first driver
                </p>
                <p>
                    Add drivers with their license details and safety scores.
                </p>
            </field>
        </record>

        <!-- ============================================================
             LIST VIEW
        ============================================================ -->
        <record id="view_transit_driver_list" model="ir.ui.view">
            <field name="name">transit.driver.list</field>
            <field name="model">transit.driver</field>
            <field name="arch" type="xml">
                <list string="Drivers"
                      decoration-success="status == 'available' and license_valid"
                      decoration-warning="status == 'off_duty'"
                      decoration-danger="status == 'suspended' or not license_valid"
                      decoration-info="status == 'on_trip'">
                    <field name="name"/>
                    <field name="license_number"/>
                    <field name="license_category"/>
                    <field name="license_expiry_date"/>
                    <field name="license_valid" widget="boolean"/>
                    <field name="days_to_expiry"/>
                    <field name="contact_number"/>
                    <field name="safety_score" widget="progressbar" string="Safety"/>
                    <field name="status" widget="badge"
                           decoration-success="status == 'available'"
                           decoration-info="status == 'on_trip'"
                           decoration-warning="status == 'off_duty'"
                           decoration-danger="status == 'suspended'"/>
                    <field name="total_trips_completed" string="Trips"/>
                </list>
            </field>
        </record>

        <!-- ============================================================
             FORM VIEW
        ============================================================ -->
        <record id="view_transit_driver_form" model="ir.ui.view">
            <field name="name">transit.driver.form</field>
            <field name="model">transit.driver</field>
            <field name="arch" type="xml">
                <form string="Driver">
                    <header>
                        <field name="status" widget="statusbar"
                               statusbar_visible="available,on_trip,off_duty,suspended"/>
                        <button name="action_set_available"
                                string="Set Available"
                                type="object"
                                class="btn-success"
                                groups="transitops.group_transitops_fleet_manager"
                                invisible="status == 'available'"/>
                        <button name="action_set_off_duty"
                                string="Set Off Duty"
                                type="object"
                                class="btn-warning"
                                groups="transitops.group_transitops_fleet_manager"
                                invisible="status in ('off_duty', 'suspended', 'on_trip')"/>
                        <button name="action_suspend"
                                string="Suspend Driver"
                                type="object"
                                class="btn-danger"
                                groups="transitops.group_transitops_fleet_manager"
                                invisible="status == 'suspended'"
                                confirm="Are you sure you want to suspend this driver?"/>
                    </header>

                    <sheet>
                        <!-- Stat Buttons -->
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_trips"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-road">
                                <field name="trip_count" widget="statinfo" string="Trips"/>
                            </button>
                        </div>

                        <!-- Photo + Title -->
                        <field name="photo" widget="image" class="oe_avatar"
                               options="{'preview_image': 'photo'}"/>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Full Name..." required="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="License Information">
                                <field name="license_number" required="1"/>
                                <field name="license_category" required="1"/>
                                <field name="license_expiry_date" required="1"/>
                                <field name="license_valid" readonly="1"
                                       widget="boolean"
                                       decoration-danger="not license_valid"
                                       decoration-success="license_valid"/>
                                <field name="days_to_expiry" readonly="1"/>
                            </group>
                            <group string="Personal &amp; Safety">
                                <field name="contact_number"/>
                                <field name="safety_score"/>
                                <field name="status" readonly="1"/>
                            </group>
                        </group>

                        <!-- Performance Stats -->
                        <group string="Performance Statistics" col="2">
                            <field name="total_trips_completed" readonly="1"/>
                            <field name="total_distance_driven" readonly="1" string="Total Distance (km)"/>
                        </group>

                        <!-- Trip History Tab -->
                        <notebook>
                            <page string="Trip History" name="trips">
                                <field name="trip_ids" readonly="1">
                                    <list>
                                        <field name="trip_number"/>
                                        <field name="vehicle_id"/>
                                        <field name="source"/>
                                        <field name="destination"/>
                                        <field name="dispatch_date"/>
                                        <field name="completion_date"/>
                                        <field name="actual_distance"/>
                                        <field name="status" widget="badge"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>

                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- ============================================================
             KANBAN VIEW
        ============================================================ -->
        <record id="view_transit_driver_kanban" model="ir.ui.view">
            <field name="name">transit.driver.kanban</field>
            <field name="model">transit.driver</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status">
                    <field name="name"/>
                    <field name="license_number"/>
                    <field name="license_valid"/>
                    <field name="license_expiry_date"/>
                    <field name="safety_score"/>
                    <field name="status"/>
                    <field name="total_trips_completed"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <field name="photo" widget="image"
                                       class="o_kanban_image"
                                       options="{'img_class': 'o_image_64_cover'}"/>
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <ul class="list-unstyled mb-0 mt-1">
                                        <li>
                                            <span class="text-muted">License: </span>
                                            <field name="license_number"/>
                                        </li>
                                        <li>
                                            <span class="text-muted">Expiry: </span>
                                            <field name="license_expiry_date"/>
                                        </li>
                                        <li>
                                            <span class="text-muted">Safety Score: </span>
                                            <field name="safety_score"/>%
                                        </li>
                                        <li>
                                            <span class="text-muted">Trips: </span>
                                            <field name="total_trips_completed"/>
                                        </li>
                                    </ul>
                                    <div class="mt-2">
                                        <field name="status" widget="badge"/>
                                        <field name="license_valid" widget="boolean"
                                               class="ms-2"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ============================================================
             SEARCH VIEW
        ============================================================ -->
        <record id="view_transit_driver_search" model="ir.ui.view">
            <field name="name">transit.driver.search</field>
            <field name="model">transit.driver</field>
            <field name="arch" type="xml">
                <search string="Search Drivers">
                    <field name="name" string="Name / License"
                           filter_domain="['|', ('name', 'ilike', self), ('license_number', 'ilike', self)]"/>
                    <field name="license_number"/>
                    <field name="license_category"/>

                    <filter string="Available" name="filter_available"
                            domain="[('status', '=', 'available'), ('license_valid', '=', True)]"/>
                    <filter string="On Trip" name="filter_on_trip"
                            domain="[('status', '=', 'on_trip')]"/>
                    <filter string="Off Duty" name="filter_off_duty"
                            domain="[('status', '=', 'off_duty')]"/>
                    <filter string="Suspended" name="filter_suspended"
                            domain="[('status', '=', 'suspended')]"/>
                    <separator/>
                    <filter string="Valid License" name="filter_valid_license"
                            domain="[('license_valid', '=', True)]"/>
                    <filter string="Expired License" name="filter_expired_license"
                            domain="[('license_valid', '=', False)]"/>
                    <filter string="Expiring Soon (30 days)" name="filter_expiring"
                            domain="[('days_to_expiry', '&gt;=', 0), ('days_to_expiry', '&lt;=', 30)]"/>

                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                        <filter string="License Category" name="group_category" context="{'group_by': 'license_category'}"/>
                    </group>
                </search>
            </field>
        </record>

    </data>
</odoo>
